  "panels": [
    {
      "id": 1,
      "title": "Client SLA Timeline",
      "type": "state-timeline",
      "datasource": "Prometheus",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "probe_success{job=\"client_uptime\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#EF4444", "value": null },
              { "color": "#10B981", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "hidden", "placement": "bottom", "showLegend": false },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 2,
      "title": "Active Platform Users",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 5 },
      "targets": [
        {
          "expr": "max(active_platform_users)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#2563EB", "mode": "fixed" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value"
      }
    },
