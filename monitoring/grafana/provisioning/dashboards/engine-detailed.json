    {
      "id": 11,
      "title": "Copilot Prompt Size P90",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.9, sum(rate(copilot_user_message_length_bucket[$__rate_interval])) by (le))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "fixedColor": "#8B5CF6", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 18,
            "gradientMode": "opacity",
            "lineWidth": 3,
            "showPoints": "never",
            "spanNulls": false
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 12,
      "title": "Request vs Response Throughput",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "sum(rate(http_request_size_bytes_sum{job=\"engine\",handler!~\"/metrics|/docs|/openapi.json\"}[$__rate_interval]))",
          "legendFormat": "request bytes/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_response_size_bytes_sum{job=\"engine\",handler!~\"/metrics|/docs|/openapi.json\"}[$__rate_interval]))",
          "legendFormat": "response bytes/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "lineWidth": 3,
            "showPoints": "never",
            "spanNulls": false
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 13,
      "title": "Engine Resident Memory",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"engine\"}",
